# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Aegis GRC Platform
APP_ENV=development          # development | staging | production
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string-in-production

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL with pgvector extension
DATABASE_URL=postgresql+asyncpg://aegis:aegis@localhost:5432/aegis
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-another-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...        # used only for embeddings
EMBEDDING_MODEL=text-embedding-3-small
CLAUDE_MODEL=claude-sonnet-4-6

# ── Integrations ─────────────────────────────────────────────────────────────
# Okta (per-org — stored in DB, these are defaults for dev)
OKTA_DOMAIN=your-org.okta.com
OKTA_API_KEY=

# AWS Security Hub
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1

# NVD (National Vulnerability Database)
NVD_API_KEY=              # optional, increases rate limits

# ── File Storage ─────────────────────────────────────────────────────────────
S3_ENDPOINT_URL=          # leave empty for AWS, set for Cloudflare R2
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=aegis-evidence
S3_REGION=auto

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
